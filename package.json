{
    "name": "@bensitu/image-editor",
    "version": "1.4.2",
    "description": "Lightweight canvas-based image editor",
    "main": "./dist/image-editor.js",
    "module": "./dist/image-editor.esm.mjs",
    "types": "./image-editor.d.ts",
    "exports": {
        ".": {
            "types": "./image-editor.d.ts",
            "import": "./dist/image-editor.esm.mjs",
            "default": "./dist/image-editor.js"
        }
    },
    "scripts": {
        "dev": "node esbuild.config.mjs --watch",
        "build": "node esbuild.config.mjs",
        "build:babel": "babel src --out-dir dist --copy-files",
        "lint": "eslint src docs/js",
        "test": "npm run build && node --test tests/image-editor.test.mjs tests/package.test.mjs"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bensitu/image-editor.git"
    },
    "author": "Ben Situ",
    "license": "MIT",
    "files": [
        "dist",
        "src",
        "image-editor.d.ts"
    ],
    "peerDependencies": {
        "fabric": "^5.5.2"
    },
    "publishConfig": {
        "access": "public"
    },
    "devDependencies": {
        "@babel/cli": "^7.22.9",
        "@babel/core": "^7.22.9",
        "@babel/preset-env": "^7.22.9",
        "@eslint/js": "^10.0.1",
        "canvas": "^3.2.3",
        "esbuild": "^0.28.0",
        "esbuild-plugin-babel": "^0.2.3",
        "eslint": "^10.4.0",
        "fabric": "^5.5.2",
        "globals": "^17.6.0"
    },
    "browserslist": [
        "Chrome >= 100",
        "Firefox >= 100",
        "Safari >= 15",
        "Edge >= 100"
    ],
    "keywords": [
        "fabricjs",
        "image-editor",
        "javascript",
        "mask",
        "open-source"
    ],
    "directories": {
        "doc": "docs"
    },
    "bugs": {
        "url": "https://github.com/bensitu/image-editor/issues"
    },
    "homepage": "https://github.com/bensitu/image-editor#readme",
    "babel": {
        "presets": [
            [
                "@babel/preset-env",
                {
                    "targets": {
                        "chrome": "100",
                        "firefox": "100",
                        "safari": "15",
                        "edge": "100"
                    },
                    "useBuiltIns": false,
                    "modules": false
                }
            ]
        ]
    }
}
