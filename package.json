            }
        },
        "./plugins/mask": {
            "import": {
                "types": "./dist/types/plugins/mask/index.d.ts",
                "default": "./dist/esm/plugins/mask/index.js"
            },
            "require": {
                "types": "./dist/types/plugins/mask/index.d.cts",
