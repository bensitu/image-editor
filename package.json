                "default": "./dist/cjs/sdk/index.cjs"
            }
        },
        "./testing": {
            "import": {
                "types": "./dist/types/testing/index.d.ts",
                "default": "./dist/esm/testing/index.js"
            },
            "require": {
                "types": "./dist/types/testing/index.d.cts",
                "default": "./dist/cjs/testing/index.cjs"
            }
        },
        "./migrate-v2": {
            "import": {
