/**
 * tsconfig.cjs.json — SUPERSEDED BY ROLLUP
 *
 * This file previously drove the CJS build via `tsc -p tsconfig.cjs.json`.
 * That approach had a fundamental conflict:
 *
 *   - Source imports use `.js` extensions  (e.g. `./image-editor.js`)
 *     which is correct for ESM / "moduleResolution": "bundler".
 *   - `"module": "CommonJS"` requires `"moduleResolution": "node"` (node10),
 *     which does NOT map `.js` → `.ts`, so tsc would fail with
 *     "Cannot find module './image-editor.js'".
 *   - Switching to `"moduleResolution": "node16"` requires
 *     `"module": "node16"` too; mixing them raises a TypeScript error.
 *
 * The CJS build is now handled by Rollup (rollup.config.mjs, FORMAT=cjs),
 * which resolves `.js` extensions correctly through @rollup/plugin-node-resolve.
 *
 * npm script: `npm run build:cjs`  →  rollup -c --environment FORMAT:cjs
 *
 * This file is kept for historical reference only and is NOT referenced by
 * any build script.
 */
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist/cjs",
    "declaration": false,
    "declarationMap": false
  }
}
